// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "diff_view_style": "unified",
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "button": true,
    "enabled": true
  },
  "auto_install_extensions": {
    "fish": true,
    "html": true,
    "ruby": true,
    "typst": true,
    "typos": true,
    "xcode-themes": true
  },
  "autosave": "on_focus_change",
  "buffer_font_family": "Fira Code",
  "buffer_font_size": 12,
  "colorize_brackets": true,
  "confirm_quit": true,
  "cursor_blink": false,
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  "disable_ai": false,
  "edit_predictions": {
    "provider": "none"
  },
  "file_types": {
    "Ruby": ["**/rakefile"],
  },
  "format_on_save": "off",
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    }
  },
  "indent_guides": {
    "coloring": "indent_aware"
  },
  "inlay_hints": {
    "enabled": true
  },
  "minimap": {
    "show": "auto"
  },
  "preferred_line_length": 120,
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": true,
    "git_status_indicator": true,
    "sort_mode": "mixed"
  },
  "sticky_scroll": {
    "enabled": true
  },
  "tab_size": 2,
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors"
  },
  "telemetry": {
    "metrics": false
  },
  "terminal": {
    "blinking": "off",
    "cursor_shape": "underline"
  },
  "theme": {
    "dark": "Mist Dark",
    "light": "Mist Light",
    "mode": "system"
  },
  "title_bar": {
    "show_sign_in": false,
  },
}
